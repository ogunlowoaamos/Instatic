{
  "compilerOptions": {
    "target": "ES2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "declaration": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "noEmit": false,
    "lib": [
      "ES2020",
      "DOM"
    ]
  },
  "include": [
    "types.ts",
    "icons/**/*.tsx"
  ]
}
