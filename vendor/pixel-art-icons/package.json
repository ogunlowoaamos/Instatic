{
  "name": "pixel-art-icons",
  "version": "0.0.0-vendored",
  "description": "Vendored subset of pixel-art-icons. Generated by scripts/sync-icons.ts — do not edit by hand.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./icons/*": {
      "types": "./dist/icons/*.d.ts",
      "default": "./dist/icons/*.js"
    }
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
