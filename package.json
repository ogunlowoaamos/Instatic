{
  "name": "page-builder",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:agent": "bun run dev:server",
    "dev:server": "bun --watch server/index.ts",
    "dev:vite": "vite",
    "docker:up": "docker compose -f compose.prod.yml -f compose.build.yml up --build",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-dir=.coverage && bun run scripts/lcov-to-istanbul.ts",
    "fallow:health": "bun run test:coverage && npx fallow health --coverage .coverage/coverage-final.json",
    "icons:sync": "bun run scripts/sync-icons.ts",
    "icons:check": "bun run scripts/sync-icons.ts --check",
    "pb-plugin": "bun run src/core/plugin-sdk/cli/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.126",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@dnd-kit/core": "^6.3.1",
    "@fallow-cli/beacon": "^0.4.3",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@lezer/highlight": "^1.2.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sinclair/typebox": "^0.34.49",
    "@use-gesture/react": "^10.3.1",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.2",
    "fflate": "^0.8.2",
    "happy-dom": "^20.9.0",
    "html-to-image": "^1.11.13",
    "immer": "^11.1.4",
    "lru-cache": "^11.3.5",
    "marked": "^18.0.3",
    "nanoid": "^5.1.11",
    "pixel-art-icons": "file:./vendor/pixel-art-icons",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "semver": "^7.7.4",
    "zod": "^4.4.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@codemirror/view": "^6.41.1",
    "@eslint/js": "^10.0.1",
    "@secretlint/secretlint-rule-preset-recommend": "^12.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.13",
    "@types/node": "^24.12.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^6.0.1",
    "dependency-cruiser": "^17.4.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jscpd": "^4.0.9",
    "knip": "^6.11.0",
    "madge": "^8.0.0",
    "secretlint": "^12.3.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10"
  }
}
